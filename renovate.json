{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "schedule": ["before 5am on monday"],
  "automerge": false,
  "automergeType": "branch",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all minor and patch updates",
      "automerge": false
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "major updates",
      "automerge": false
    }
  ]
}
