{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@components/*": [
                "src/components/*"
            ],
            "@layouts/*": [
                "src/layouts/*"
            ],
            "@styles/*": [
                "src/styles/*"
            ],
            "@images/*": [
                "src/images/*"
            ],
            "@icons/*": [
                "src/icons/*"
            ],
            "@lib/*": [
                "src/lib/*"
            ],
            "@content/*": [
                "src/content/*"
            ]
        },
        "jsx": "react-jsx",
        "jsxImportSource": "preact"
    }
}