---
interface Props {
	href?: string;
	variant?: "primary" | "link";
	size?: "sm" | "md" | "lg";
	external?: boolean;
}

const { href, variant = "primary", size = "md", external = false } = Astro.props;

const Tag = href ? "a" : "button";
const externalAttrs = external ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

<Tag href={href} data-variant={variant} data-size={size} {...externalAttrs}>
	<slot />
</Tag>

<style>
	:where(a, button) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-heading);
		font-weight: 600;
		text-decoration: none;
		border: none;
		cursor: pointer;
		transition:
			transform var(--transition-fast),
			opacity var(--transition-fast);
	}

	:where(a, button):hover {
		transform: scale(1.05);
	}

	:where(a, button):active {
		transform: scale(0.98);
	}

	/* Primary variant - gradient background */
	:where(a, button)[data-variant="primary"] {
		background: var(--gradient-brand);
		background-size: 200% 100%;
		color: var(--color-white);
		border-radius: var(--radius-full);
		transition:
			background-position var(--transition-base),
			transform var(--transition-fast);
	}

	:where(a, button)[data-variant="primary"]:hover {
		background-position: 100% 0;
	}

	/* Link variant - text only */
	:where(a, button)[data-variant="link"] {
		background: none;
		color: var(--color-text);
		padding: 0;
	}

	:where(a, button)[data-variant="link"]:hover {
		color: var(--color-pink);
	}

	/* Sizes */
	:where(a, button)[data-size="sm"] {
		font-size: var(--text-sm);
		padding: var(--space-2) var(--space-4);
	}

	:where(a, button)[data-size="md"] {
		font-size: var(--text-base);
		padding: var(--space-3) var(--space-6);
	}

	:where(a, button)[data-size="lg"] {
		font-size: var(--text-lg);
		padding: var(--space-4) var(--space-8);
	}

	/* Link variant ignores padding */
	:where(a, button)[data-variant="link"][data-size="sm"],
	:where(a, button)[data-variant="link"][data-size="md"],
	:where(a, button)[data-variant="link"][data-size="lg"] {
		padding: var(--space-1) var(--space-2);
	}
</style>
