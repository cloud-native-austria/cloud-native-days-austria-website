---
import PersonCard from "./PersonCard.astro";
import { Icon } from "astro-icon/components";
import { getLinkTypeIcon } from "../lib/icon-map";
import { getSessionUrl } from "../lib/sessionize-app";
import type { CollectionEntry } from "astro:content";

type Speaker = CollectionEntry<"speakers">["data"];

interface Props {
	speakers: Speaker[];
}

const { speakers } = Astro.props;
---

{
	speakers.map((speaker) => (
		<article id={`speaker-${speaker.id}`} popover>
			<header>
				<div>
					<PersonCard name={speaker.fullName} image={speaker.profilePicture} showMeta={false} />
					<div>
						<h2>{speaker.fullName}</h2>
						{speaker.tagLine && <p>{speaker.tagLine}</p>}
						<div class="social-links">
							{speaker.links.map((link) => (
								<a
									href={link.url}
									target="_blank"
									rel="noopener noreferrer"
									class="social-link"
									aria-label={link.title}
								>
									<Icon name={getLinkTypeIcon(link.linkType)} width={20} height={20} />
								</a>
							))}
						</div>
					</div>
				</div>
				<button
					popovertarget={`speaker-${speaker.id}`}
					popovertargetaction="hide"
					class="close-button"
					aria-label="Close modal"
				>
					✕
				</button>
			</header>
			<div>
				{speaker.bio && (
					<section>
						<h3>Bio</h3>
						<p>{speaker.bio}</p>
					</section>
				)}
				{speaker.sessions && speaker.sessions.length > 0 && (
					<section>
						<h3>Sessions</h3>
						<ul>
							{speaker.sessions.map((session) => (
								<li>
									<a href={getSessionUrl(String(session.id))}>{session.name}</a>
								</li>
							))}
						</ul>
					</section>
				)}
			</div>
		</article>
	))
}

<style>
	[popover]:not(:popover-open) {
		display: none !important;
	}

	[popover] {
		margin: auto;
		padding: 0;
		border: none;
		border-radius: var(--radius);
		max-width: 600px;
		max-height: 85vh;
		overflow-y: auto;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
		opacity: 0;
		transform: translateY(1rem) scale(0.98);
		transition:
			opacity 220ms ease,
			transform 220ms ease,
			overlay 220ms ease allow-discrete,
			display 220ms ease allow-discrete;
	}

	[popover]:popover-open {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	[popover]::backdrop {
		background: rgba(0, 0, 0, 0.6);
		backdrop-filter: blur(4px);
		transition: background 220ms ease;
	}

	@starting-style {
		[popover]:popover-open {
			opacity: 0;
			transform: translateY(1rem) scale(0.98);
		}

		[popover]:popover-open::backdrop {
			background: rgba(0, 0, 0, 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		[popover],
		[popover]::backdrop {
			transition: none;
		}

		[popover] {
			transform: none;
		}
	}

	[popover] header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--space-4);
		padding: var(--space-6);
		border-bottom: 1px solid var(--color-gray);
		position: sticky;
		top: 0;
		background-color: var(--color-white);
	}

	[popover] header > div {
		display: flex;
		gap: var(--space-4);
		align-items: flex-start;
	}

	[popover] header > div > :nth-child(2) {
		align-self: flex-start;
	}

	[popover] header h2 {
		font-size: var(--text-xl);
		font-weight: 600;
		margin-bottom: var(--space-1);
	}

	[popover] header p {
		font-size: var(--text-base);
		color: var(--color-text-light);
		margin-bottom: var(--space-2);
	}

	[popover] header .social-links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-top: var(--space-2);
	}

	.close-button {
		all: unset;
		cursor: pointer;
		font-size: var(--text-xl);
		line-height: 1;
		color: var(--color-text-light);
		transition: color 0.2s ease;
		flex-shrink: 0;
		align-self: flex-start;
	}

	.close-button:hover {
		color: var(--color-text);
	}

	.close-button:focus-visible {
		outline: 2px solid var(--color-purple);
		outline-offset: 2px;
		border-radius: var(--radius);
	}

	[popover] > div {
		padding: var(--space-6);
	}

	[popover] > div h3 {
		font-size: var(--text-lg);
		font-weight: 600;
		margin-bottom: var(--space-3);
		color: var(--color-text);
	}

	[popover] > div > section:first-child {
		margin-bottom: var(--space-6);
	}

	[popover] > div > section:first-child p {
		line-height: 1.6;
		color: var(--color-text);
		white-space: pre-wrap;
	}

	[popover] > div > section:nth-child(2) {
		margin-bottom: var(--space-6);
	}

	[popover] > div > section:nth-child(2) ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	[popover] > div > section:nth-child(2) li {
		margin-bottom: var(--space-2);
	}

	[popover] > div > section:nth-child(2) a {
		color: var(--color-purple);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	[popover] > div > section:nth-child(2) a:hover,
	[popover] > div > section:nth-child(2) a:focus-visible {
		color: var(--color-pink);
	}

	.social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		padding: var(--space-2);
		background: var(--color-bg-light);
		color: var(--color-purple);
		text-decoration: none;
		border-radius: var(--radius-full);
		transition: all 0.2s ease;
	}

	.social-link svg {
		width: 20px;
		height: 20px;
		flex-shrink: 0;
	}

	.social-link:hover {
		background: var(--color-purple);
		color: var(--color-white);
		transform: scale(1.05);
	}

	@media (max-width: 768px) {
		[popover] header {
			padding: var(--space-4);
		}

		[popover] > div {
			padding: var(--space-4);
		}
	}
</style>

<script>
	const openSpeakerFromHash = () => {
		if (!window.location.hash) return;

		const targetId = decodeURIComponent(window.location.hash.slice(1));
		const target = document.getElementById(targetId);

		if (!target?.matches("[popover]")) return;

		const openPopover = document.querySelector("[popover]:popover-open");
		if (openPopover && openPopover !== target) {
			(openPopover as HTMLElement).hidePopover();
		}

		if (!target.matches(":popover-open")) {
			(target as HTMLElement).showPopover();
		}
	};

	openSpeakerFromHash();
	window.addEventListener("hashchange", openSpeakerFromHash);

	document.querySelectorAll("[popover]").forEach((popover) => {
		popover.addEventListener("beforetoggle", (event) => {
			if (!(event instanceof ToggleEvent)) return;
			if (event.newState !== "closed") return;
			if (window.location.hash !== `#${popover.id}`) return;

			history.replaceState(null, "", `${window.location.pathname}${window.location.search}`);
		});
	});

	document.querySelectorAll("a[data-speaker-target]").forEach((link) => {
		link.addEventListener("click", () => {
			const targetId = link.getAttribute("data-speaker-target");
			if (!targetId) return;

			if (window.location.hash === `#${targetId}`) {
				openSpeakerFromHash();
			}
		});
	});
</script>
