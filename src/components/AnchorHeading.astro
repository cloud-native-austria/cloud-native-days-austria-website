---
/**
 * AnchorHeading component for MDX content
 * Creates headings with anchor links for easy navigation
 */

interface Props {
  level: 1 | 2 | 3 | 4 | 5 | 6;
  id?: string;
}

const { level, id } = Astro.props;
const Tag = `h${level}` as keyof HTMLElementTagNameMap;
---

<Tag id={id} class="anchor-heading">
  <slot />
  {
    id && (
      <a href={`#${id}`} aria-label={`Link to this section: ${id}`} class="anchor-link">
        #
      </a>
    )
  }
</Tag>

<style>
  .anchor-heading {
    position: relative;
  }

  .anchor-link {
    position: absolute;
    left: -1.5rem;
    opacity: 0;
    text-decoration: none;
    color: var(--color-purple);
    font-weight: 400;
    transition: opacity 0.2s ease;
  }

  .anchor-heading:hover .anchor-link {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .anchor-link {
      position: static;
      opacity: 1;
      margin-left: 0.5rem;
    }
  }
</style>
