---
import { Image } from "astro:assets";
import logo from "./logo.svg";

interface Props {
	homepage?: boolean;
}

const { homepage = false } = Astro.props;

const menuItems = [
	{ text: "Speakers", to: "/speakers", id: "speakers" },
	{ text: "Tickets", to: "/#tickets", homeTo: "/", id: "tickets" },
	{ text: "Venue", to: "/#venue", homeTo: "/", id: "venue" },
	{ text: "Sponsors", to: "/#sponsors", homeTo: "/", id: "sponsors" },
];
---

<header>
	<section>
		<a href="/" aria-label="Go to Homepage">
			<Image src={logo} alt="Cloud Native Days Austria" width="176" height="48" />
		</a>

		<nav aria-label="Main navigation">
			<ul>
				{
					menuItems.map(({ text, to, homeTo, id }) => (
						<li>
							<a href={homepage && homeTo ? homeTo : to} data-nav-id={id}>
								{text}
							</a>
						</li>
					))
				}
			</ul>
		</nav>

		<button
			id="mobile-menu-toggle"
			type="button"
			aria-label="Toggle menu"
			popovertarget="mobile-menu"
		>
			<span></span>
		</button>

		<nav id="mobile-menu" popover aria-label="Mobile navigation">
			<ul>
				{
					menuItems.map(({ text, to, homeTo, id }) => (
						<li>
							<a href={homepage && homeTo ? homeTo : to} data-nav-id={id}>
								{text}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</section>
</header>

<style>
	header {
		background: var(--color-white);
		border-bottom: 1px solid var(--color-gray);
		padding: var(--space-4) 0;
	}

	header section {
		width: 100%;
		max-width: var(--container);
		margin-inline: auto;
		padding-inline: var(--page-inline-padding);
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	header img {
		height: 48px;
		width: auto;
	}

	/* Desktop Navigation */
	nav:first-of-type ul {
		display: flex;
		gap: var(--space-6);
		list-style: none;
		padding: 0;
	}

	nav:first-of-type a,
	#mobile-menu a {
		font-family: var(--font-heading);
		font-weight: 600;
		color: var(--color-text);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	nav:first-of-type a {
		font-size: var(--text-base);
	}

	nav:first-of-type a:hover,
	#mobile-menu a:hover {
		color: var(--color-pink);
	}

	/* Mobile Menu Button */
	#mobile-menu-toggle {
		display: none;
		z-index: 60;
		anchor-name: --mobile-menu-toggle;
		background: none;
		border: 0;
		cursor: pointer;
		padding: 0;
		width: 44px;
		height: 44px;
		align-items: center;
		justify-content: center;
	}

	#mobile-menu-toggle > span,
	#mobile-menu-toggle > span::before,
	#mobile-menu-toggle > span::after {
		display: block;
		width: 24px;
		height: 2px;
		background-color: var(--color-text);
		transition: transform var(--transition-base);
	}

	#mobile-menu-toggle > span {
		position: relative;
	}

	#mobile-menu-toggle > span::before,
	#mobile-menu-toggle > span::after {
		content: "";
		position: absolute;
		left: 0;
	}

	#mobile-menu-toggle > span::before {
		top: -8px;
	}

	#mobile-menu-toggle > span::after {
		top: 8px;
	}

	header section:has(#mobile-menu:popover-open) #mobile-menu-toggle > span {
		background-color: transparent;
	}

	header section:has(#mobile-menu:popover-open) #mobile-menu-toggle > span::before {
		transform: translateY(8px) rotate(45deg);
	}

	header section:has(#mobile-menu:popover-open) #mobile-menu-toggle > span::after {
		transform: translateY(-8px) rotate(-45deg);
	}

	/* Mobile Menu Popover */
	#mobile-menu {
		position: fixed;
		top: calc((var(--space-4) * 2) + 48px + 1px);
		left: auto;
		right: var(--page-inline-padding);
		width: fit-content;
		max-width: calc(100vw - (var(--page-inline-padding) * 2));
		margin: 0;
		padding: var(--space-6) var(--page-inline-padding);
		border: none;
		background: var(--color-white);
		border-top: 1px solid var(--color-gray);
		box-shadow: var(--shadow-elevated);
		z-index: 50;
		transform-origin: top right;
		opacity: 0;
		transform: translateY(-0.5rem) scale(0.98);
		transition:
			opacity var(--transition-base),
			transform var(--transition-base),
			overlay var(--transition-base) allow-discrete,
			display var(--transition-base) allow-discrete;
	}

	@supports (position-anchor: --mobile-menu-toggle) {
		#mobile-menu {
			position-anchor: --mobile-menu-toggle;
			top: calc(anchor(bottom) + var(--space-4));
			right: anchor(right);
		}
	}

	#mobile-menu:popover-open {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	#mobile-menu ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		align-items: flex-end;
	}

	#mobile-menu a {
		font-size: var(--text-lg);
		display: block;
		padding: var(--space-1) 0;
	}

	#mobile-menu::backdrop {
		background: transparent;
	}

	@starting-style {
		#mobile-menu:popover-open {
			opacity: 0;
			transform: translateY(-0.5rem) scale(0.98);
		}
	}

	@media (max-width: 768px) {
		nav:first-of-type {
			display: none;
		}

		#mobile-menu-toggle {
			display: flex;
		}
	}

	@media (min-width: 768px) {
		#mobile-menu-toggle,
		#mobile-menu {
			display: none !important;
		}
	}
</style>

<script>
	const mobileMenu = document.getElementById("mobile-menu");
	if (mobileMenu && "hidePopover" in mobileMenu) {
		const mobileMenuLinks = mobileMenu.querySelectorAll("a");
		mobileMenuLinks.forEach((link) => {
			link.addEventListener("click", () => {
				mobileMenu.hidePopover();
			});
		});
	}
</script>
