---
interface Props {
  name: string;
  role?: string;
  image: string;
  links?: Array<{
    url: string;
    label: string;
  }>;
}

const { name, role, image, links = [] } = Astro.props;
---

<article class="person">
  <div class="image-wrapper">
    <img src={image} alt={name} class="heptagon" loading="lazy" decoding="async" />
  </div>
  <h3 class="name">{name}</h3>
  {role && <p class="role">{role}</p>}
  {
    links.length > 0 && (
      <div class="links">
        {links.map(({ url, label }) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${name} on ${label}`}
          >
            {label}
          </a>
        ))}
      </div>
    )
  }
</article>

<style>
  .person {
    text-align: center;
  }

  .image-wrapper {
    width: 180px;
    height: 180px;
    margin-inline: auto;
    margin-bottom: var(--space-4);
    filter: drop-shadow(0 8px 16px rgba(38, 47, 89, 0.15));
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .name {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }

  .role {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-2);
  }

  .links {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
  }

  .links a {
    font-size: var(--text-xs);
    color: var(--color-purple);
    text-decoration: none;
  }

  .links a:hover {
    color: var(--color-pink);
  }
</style>
