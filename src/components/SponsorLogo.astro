---
import { Picture } from "astro:assets";

interface Props {
	name: string;
	logo: string;
	url?: string;
	tier?: "platinum" | "gold" | "silver" | "bronze" | "community";
}

const { name, logo, url, tier = "silver" } = Astro.props;

const sizes = {
	platinum: 200,
	gold: 160,
	silver: 140,
	bronze: 120,
	community: 100,
};

const size = sizes[tier];
---

{
	url ? (
		<a href={url} target="_blank" rel="noopener noreferrer" aria-label={name}>
			<Picture src={logo} alt={name} width={size} height={size} formats={["avif", "webp"]} />
		</a>
	) : (
		<div>
			<Picture src={logo} alt={name} width={size} height={size} formats={["avif", "webp"]} />
		</div>
	)
}

<style>
	a,
	div {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-4);
		transition: transform var(--transition-fast);
	}

	a:hover {
		transform: scale(1.05);
	}

	img {
		max-width: 100%;
		height: auto;
		object-fit: contain;
	}
</style>
