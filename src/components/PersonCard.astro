---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
	name: string;
	role?: string | null;
	image: ImageMetadata | string;
	showMeta?: boolean;
	sizes?: string;
}

const { name, role, image, showMeta = true, sizes = "200px" } = Astro.props;
---

<div>
	{
		typeof image === "string" ? (
			<Picture
				src={image}
				alt={name}
				class="heptagon"
				formats={["avif", "webp"]}
				loading="lazy"
				decoding="async"
				sizes={sizes}
				height={200}
				width={200}
			/>
		) : (
			<Picture
				src={image}
				alt={name}
				class="heptagon"
				formats={["avif", "webp"]}
				loading="lazy"
				decoding="async"
				sizes={sizes}
				height={200}
				width={200}
			/>
		)
	}
	{showMeta && <h3>{name}</h3>}
	{showMeta && role && <p>{role}</p>}
</div>

<style>
	div {
		text-align: center;
	}

	picture,
	img {
		margin: 0 auto;
		width: 100%;
		height: 100%;
		aspect-ratio: 1/1;
		object-fit: cover;
		filter: drop-shadow(0 6px 6px rgb(0 0 0 / 0.24));
	}

	h3 {
		font-family: var(--font-heading);
		font-size: var(--text-lg);
		margin-block: var(--space-2);
		color: var(--color-text);
		transition: color 0.2s ease;
	}

	:global(a:hover) h3,
	:global(a:focus-visible) h3 {
		color: var(--color-pink);
	}

	p {
		font-size: var(--text-base);
		color: var(--color-text-light);
		line-height: 1.5;
	}
</style>
