---
import Container from "@components/Container.astro";

interface Props {
	homepage?: boolean;
}

const { homepage = false } = Astro.props;

const menuItems = [
	{ text: "Speakers", to: "/speakers" },
	{ text: "Venue", to: "/#venue", homeTo: "/" },
	{ text: "Sponsors", to: "/#sponsors", homeTo: "/" },
];
---

<header>
	<Container>
		<a href="/" aria-label="Go to Homepage">
			<img src="/images/logo.svg" alt="Cloud Native Days Austria" width="176" height="48" />
		</a>

		<nav aria-label="Main navigation">
			<ul>
				{
					menuItems.map(({ text, to, homeTo }) => (
						<li>
							<a href={homepage && homeTo ? homeTo : to}>{text}</a>
						</li>
					))
				}
			</ul>
		</nav>

		<details>
			<summary aria-label="Toggle menu">
				<span></span>
			</summary>
			<nav aria-label="Mobile navigation">
				<ul>
					{
						menuItems.map(({ text, to, homeTo }) => (
							<li>
								<a href={homepage && homeTo ? homeTo : to}>{text}</a>
							</li>
						))
					}
				</ul>
			</nav>
		</details>
	</Container>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--color-gray-10);
		padding: var(--space-4) 0;
	}

	header :global(.container) {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	header > :global(.container) > a {
		z-index: 60;
	}

	header img {
		height: 48px;
		width: auto;
	}

	/* Desktop Navigation */
	nav:first-of-type ul {
		display: flex;
		gap: var(--space-6);
		list-style: none;
		padding: 0;
	}

	nav:first-of-type a {
		font-family: var(--font-heading);
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-text);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	nav:first-of-type a:hover {
		color: var(--color-pink);
	}

	@media (max-width: 768px) {
		nav:first-of-type {
			display: none;
		}
	}

	/* Mobile Menu */
	details {
		display: none;
		z-index: 60;
	}

	@media (max-width: 768px) {
		details {
			display: block;
		}
	}

	summary {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		cursor: pointer;
		list-style: none;
	}

	summary::-webkit-details-marker {
		display: none;
	}

	summary > span,
	summary > span::before,
	summary > span::after {
		display: block;
		width: 24px;
		height: 2px;
		background-color: var(--color-text);
		transition:
			transform var(--transition-base),
			opacity var(--transition-base);
	}

	summary > span {
		position: relative;
	}

	summary > span::before,
	summary > span::after {
		content: "";
		position: absolute;
		left: 0;
	}

	summary > span::before {
		top: -8px;
	}

	summary > span::after {
		top: 8px;
	}

	/* Burger animation when open */
	details[open] summary > span {
		background-color: transparent;
	}

	details[open] summary > span::before {
		transform: translateY(8px) rotate(45deg);
	}

	details[open] summary > span::after {
		transform: translateY(-8px) rotate(-45deg);
	}

	/* Mobile Navigation Panel */
	details > nav {
		position: fixed;
		top: 81px;
		left: 0;
		right: 0;
		bottom: 0;
		background: var(--color-white);
		padding: var(--space-8);
		animation: slideIn var(--transition-base);
	}

	@keyframes slideIn {
		from {
			opacity: 0;
			transform: translateY(-10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	details > nav ul {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
	}

	details > nav a {
		font-family: var(--font-heading);
		font-size: var(--text-xl);
		font-weight: 600;
		color: var(--color-text);
		text-decoration: none;
		display: block;
		padding: var(--space-2) 0;
	}

	details > nav a:hover {
		color: var(--color-pink);
	}
</style>
