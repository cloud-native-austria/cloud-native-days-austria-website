---
import { Picture } from 'astro:assets';

// Sponsor data - logos are served from public/images/sponsors/
const sponsors = [
  {
    title: 'Gold',
    tier: 'gold',
    sponsors: [
      { name: 'Whizus', url: 'https://www.whizus.com', logo: '/images/sponsors/Whizus.png' },
      { name: 'Exoscale', url: 'https://www.exoscale.com/', logo: '/images/sponsors/Exoscale.png' },
      {
        name: 'Dynatrace',
        url: 'https://www.dynatrace.com/',
        logo: '/images/sponsors/Dynatrace.png',
      },
      { name: 'Splunk', url: 'https://www.splunk.com/', logo: '/images/sponsors/splunk.jpg' },
    ],
  },
  {
    title: 'Silver',
    tier: 'silver',
    sponsors: [
      {
        name: 'Raiffeisen Bank International',
        url: 'https://rbinternational.com',
        logo: '/images/sponsors/RaiffeisenBankInternational.png',
      },
      {
        name: 'FullStacks',
        url: 'https://www.fullstacks.eu',
        logo: '/images/sponsors/FullStacks.png',
      },
      {
        name: 'CloudWerkstatt',
        url: 'https://www.cloudwerkstatt.com',
        logo: '/images/sponsors/CloudWerkstatt.png',
      },
      {
        name: 'NextLayer',
        url: 'https://www.nextlayer.at',
        logo: '/images/sponsors/NextLayer.webp',
      },
      { name: 'Veeam', url: 'https://www.veeam.com', logo: '/images/sponsors/Veeam.png' },
      { name: 'Post', url: 'https://www.post.at/', logo: '/images/sponsors/Post.png' },
      { name: 'squer', url: 'https://www.squer.io/', logo: '/images/sponsors/squer.png' },
    ],
  },
  {
    title: 'Community',
    tier: 'community',
    sponsors: [
      { name: 'AWS', url: 'https://aws.amazon.com/', logo: '/images/sponsors/aws.png' },
      { name: 'CNCF', url: 'https://www.cncf.io', logo: '/images/sponsors/cncf.png' },
      { name: 'Posedio', url: 'https://www.posedio.com', logo: '/images/sponsors/Posedio.svg' },
      {
        name: 'Frequentis',
        url: 'https://www.frequentis.com',
        logo: '/images/sponsors/Frequentis.png',
      },
    ],
  },
  {
    title: 'Media Partners',
    tier: 'community',
    sponsors: [
      {
        name: 'KubeCareers',
        url: 'https://kube.careers',
        logo: '/images/sponsors/KubeCareers.svg',
      },
      { name: 'KubeEvents', url: 'https://kube.events', logo: '/images/sponsors/KubeEvents.svg' },
    ],
  },
];

// Shuffle sponsors at build time for each tier
function shuffleArray<T>(array: T[]): T[] {
  const shuffled = [...array];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled;
}
---

<section class="sponsors-list">
  <h2 id="sponsors">Our Sponsors of CNDA 2025</h2>
  <p class="subtitle">Without them this event wouldn't have been possible</p>

  {
    sponsors.map(({ title, tier, sponsors: tierSponsors }) => (
      <div class="tier">
        <h3>{title}</h3>
        <div class:list={['tier-logos', `tier-${tier}`]}>
          {shuffleArray(tierSponsors).map(({ name, url, logo }) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="sponsor-link"
              aria-label={name}
            >
              <Picture src={logo} alt={name} width={200} height={100} formats={['avif', 'webp']} />
            </a>
          ))}
        </div>
      </div>
    ))
  }
</section>

<style>
  .sponsors-list {
    max-width: var(--container-lg);
    margin-inline: auto;
    padding: var(--space-12) var(--space-4);
    text-align: center;
  }

  @media (min-width: 768px) {
    .sponsors-list {
      padding-inline: var(--space-8);
    }
  }

  h2 {
    margin-bottom: var(--space-2);
  }

  .subtitle {
    color: var(--color-text-light);
    margin-bottom: var(--space-8);
  }

  .tier {
    margin-bottom: var(--space-12);
  }

  h3 {
    margin-bottom: var(--space-4);
  }

  .tier-logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
  }

  .sponsor-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4) var(--space-6);
    transition: transform var(--transition-fast);
  }

  .sponsor-link:hover {
    transform: scale(1.05);
  }

  .sponsor-link img {
    height: 70px;
    width: auto;
    max-width: 180px;
    object-fit: contain;
  }

  /* Gold tier - larger logos */
  .tier-gold .sponsor-link img {
    height: 80px;
    max-width: 200px;
  }

  /* Community tier - smaller logos */
  .tier-community .sponsor-link img {
    height: 50px;
    max-width: 140px;
  }

  @media (max-width: 768px) {
    .sponsor-link {
      width: 50%;
    }

    .sponsor-link img {
      max-width: 100%;
    }
  }
</style>
