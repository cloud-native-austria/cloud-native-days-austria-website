---
import { Picture } from "astro:assets";
import venueImage from "@images/home/venue.webp";
---

<section>
	<h2 id="venue">Venue</h2>
	<div>
		<Picture
			src={venueImage}
			alt="CDN Austria Venue - Cineplexx Wienerberg"
			formats={["avif", "webp"]}
		/>
		<a href="https://maps.app.goo.gl/Q22METdvy3f1GFfx8" target="_blank" rel="noopener noreferrer">
			<strong>Cineplexx Wienerberg</strong>
			<span>Wienerbergstraße 11, 1100 Wien</span>
		</a>
	</div>

	<div>
		<p>
			Cloud Native Days Austria are held at{" "}
			<a href="https://maps.app.goo.gl/Q22METdvy3f1GFfx8" target="_blank" rel="noopener noreferrer">
				Cineplexx Wienerberg
			</a>
			. You'll enjoy two cinema-style stages with comfy seats, great sound, and clear visuals.
		</p>
		<p>
			Grab a coffee or a bite to eat throughout the day and check out our sponsors for cool swag.
			There's plenty of space to meet new people and catch up with friends.
		</p>
		<p>Stick around for our evening event – it's right nearby!</p>
		<p>
			<strong>We can't wait to see you there!</strong>
		</p>
	</div>
</section>

<style>
	h2 {
		width: 100%;
		text-align: center;
	}

	section {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
	}

	section > div:first-of-type {
		flex: 1;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-4);
	}

	section > div:first-of-type img {
		max-height: 300px;
		width: auto;
		border-radius: var(--radius);
		object-fit: contain;
	}

	section > div:first-of-type strong {
		display: block;
		font-family: var(--font-heading);
	}

	section > div:first-of-type span {
		font-size: var(--text-sm);
	}

	section > div:last-of-type {
		flex: 1;
	}

	section > div:last-of-type p {
		margin-bottom: var(--space-4);
	}

	section > div:last-of-type p:last-child {
		margin-bottom: 0;
	}
</style>
