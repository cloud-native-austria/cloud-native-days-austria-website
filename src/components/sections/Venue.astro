---
import Container from "@components/Container.astro";
import { Picture } from "astro:assets";
import venueImage from "@images/home/venue.webp";
---

<section class="venue">
	<Container>
		<h2 id="venue">Venue</h2>

		<div>
			<div>
				<Picture
					src={venueImage}
					alt="CDN Austria Venue - Cineplexx Wienerberg"
					formats={["avif", "webp"]}
				/>
				<a
					href="https://maps.app.goo.gl/Q22METdvy3f1GFfx8"
					target="_blank"
					rel="noopener noreferrer"
				>
					<strong>Cineplexx Wienerberg</strong>
					<span>Wienerbergstraße 11, 1100 Wien</span>
				</a>
			</div>

			<div>
				<p>
					Cloud Native Days Austria are held at{" "}
					<a
						href="https://maps.app.goo.gl/Q22METdvy3f1GFfx8"
						target="_blank"
						rel="noopener noreferrer"
					>
						Cineplexx Wienerberg
					</a>
					. You'll enjoy two cinema-style stages with comfy seats, great sound, and clear visuals.
				</p>
				<p>
					Grab a coffee or a bite to eat throughout the day and check out our sponsors for cool
					swag. There's plenty of space to meet new people and catch up with friends.
				</p>
				<p>Stick around for our evening event – it's right nearby!</p>
				<p>
					<strong>We can't wait to see you there!</strong>
				</p>
			</div>
		</div>
	</Container>
</section>

<style>
	.venue {
		padding: var(--space-12) 0;
	}

	.venue :global(.container) {
		max-width: var(--container-md);
	}

	h2 {
		text-align: center;
		margin-bottom: var(--space-8);
	}

	.venue > :global(.container) > div {
		display: flex;
		gap: var(--space-8);
		align-items: flex-start;
	}

	@media (max-width: 768px) {
		.venue > :global(.container) > div {
			flex-direction: column;
		}
	}

	.venue > :global(.container) > div > div:first-child {
		flex: 1;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-4);
	}

	.venue > :global(.container) > div > div:first-child img {
		max-height: 300px;
		width: auto;
		border-radius: var(--radius-md);
		object-fit: contain;
	}

	.venue > :global(.container) > div > div:first-child a {
		display: block;
		color: var(--color-text);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.venue > :global(.container) > div > div:first-child a:hover {
		color: var(--color-pink);
	}

	.venue > :global(.container) > div > div:first-child strong {
		display: block;
		font-family: var(--font-heading);
	}

	.venue > :global(.container) > div > div:first-child span {
		font-size: var(--text-sm);
	}

	.venue > :global(.container) > div > div:last-child {
		flex: 1;
	}

	.venue > :global(.container) > div > div:last-child p {
		margin-bottom: var(--space-4);
	}

	.venue > :global(.container) > div > div:last-child p:last-child {
		margin-bottom: 0;
	}

	.venue > :global(.container) > div > div:last-child a {
		color: var(--color-purple);
	}

	.venue > :global(.container) > div > div:last-child a:hover {
		color: var(--color-pink);
	}

	@media (max-width: 768px) {
		.venue > :global(.container) > div > div:last-child {
			text-align: left;
		}
	}
</style>
