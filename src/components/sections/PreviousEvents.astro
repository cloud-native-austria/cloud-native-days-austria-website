---
import Button from "@components/Button.astro";
---

<section>
	<h2>Previous Events</h2>
	<p>Thank you all for making the Cloud Native Days Austria 2025 a fantastic event!</p>
	<p>In case you want to review previous events, check out the following links:</p>

	<article>
		<h3>Cloud Native Days Austria 2025</h3>
		<div>
			<Button href="https://www.picdrop.com/giselataschner-carl-hohenbalken/bzmm9YBJW2" external>
				Photos of the event
			</Button>
			<Button
				href="https://youtube.com/playlist?list=PLtLBTEzR4SqU9GwgWiaDt10-yOVIN0nzM&si=yQP0zXuHcyH01bHq"
				external
			>
				Recordings of the talks
			</Button>
		</div>
	</article>

	<article>
		<h3>Kubernetes Community Days Austria 2023 & 2024</h3>
		<div>
			<Button
				href="https://youtube.com/playlist?list=PLtLBTEzR4SqWKGuUBiRm_IuRZf2--CCDt&si=7ZkAV333DhWSpHp0"
				external
			>
				Recordings of 2023
			</Button>
			<Button
				href="https://www.youtube.com/playlist?list=PLtLBTEzR4SqXICiZEESHcElCqQYgjmfYR"
				external
			>
				Recordings of 2024
			</Button>
		</div>
	</article>
</section>

<style>
	section {
		text-align: center;
	}

	h2 {
		margin-bottom: var(--space-2);
	}

	article {
		margin-top: var(--space-4);
	}

	h3 {
		margin-bottom: var(--space-4);
	}

	article > div {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-2);
	}
</style>
