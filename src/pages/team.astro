---
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import Container from "@components/Container.astro";
import Layout from "@layouts/Layout.astro";

// Fetch team members from content collection
const teamMembersEntry = await getEntry("team", "members");
if (!teamMembersEntry) {
	throw new Error("Team members data not found in content collection");
}
const teamMembers = teamMembersEntry.data;
---

<Layout
	title="Team | Cloud Native Days Austria"
	description="Meet the team behind Cloud Native Days Austria. Our organizers are passionate about building the cloud native community in Austria."
>
	<main>
		<Container>
			<h1>Team</h1>
			<div>
				{
					teamMembers.map(({ name, role, image }) => (
						<article>
							<Image src={image} alt={name} format="webp" class="heptagon" />
							<h3>{name}</h3>
							<p>{role}</p>
						</article>
					))
				}
			</div>
		</Container>
	</main>
</Layout>

<style>
	main {
		padding-block: var(--space-20);
	}

	h1 {
		font-family: var(--font-heading);
		font-size: var(--text-4xl);
		text-align: center;
		margin-bottom: var(--space-16);
		color: var(--color-text);
	}

	main > :global(.container) > div {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: var(--space-10);
		justify-items: center;
	}

	article {
		text-align: center;
		max-width: 300px;
	}

	article img {
		width: 180px;
		height: 180px;
		margin-inline: auto;
		margin-bottom: var(--space-4);
		filter: drop-shadow(0 8px 16px rgba(38, 47, 89, 0.15));
		object-fit: cover;
	}

	article h3 {
		font-family: var(--font-heading);
		font-size: var(--text-lg);
		margin-bottom: var(--space-2);
		color: var(--color-text);
	}

	article p {
		font-size: var(--text-sm);
		color: var(--color-text-light);
		line-height: 1.5;
	}

	@media (max-width: 768px) {
		main {
			padding-block: var(--space-12);
		}

		h1 {
			font-size: var(--text-3xl);
			margin-bottom: var(--space-12);
		}

		main > :global(.container) > div {
			grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
			gap: var(--space-8);
		}

		article img {
			width: 150px;
			height: 150px;
		}
	}
</style>
