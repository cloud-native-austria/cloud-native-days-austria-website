---
import Layout from '@layouts/Layout.astro';
import Button from '@components/Button.astro';
import CurrentSessions from '@components/CurrentSessions';
import { scheduleUrl } from '../constants/sessionize-app';

const title = 'CNDA 2025 - Live';
const description = 'Everything you need to know at the event.';
---

<Layout title={title} description={description}>
  <div class="live-page">
    <header class="page-header">
      <h1>{title}</h1>
      <p>{description}</p>
    </header>

    <div class="live-content">
      <section class="current-sessions-section">
        <h2>Current and upcoming sessions</h2>
        <CurrentSessions client:load />
        <Button href={scheduleUrl} external variant="primary"> See the full schedule </Button>
      </section>

      <section class="info-card">
        <h2>Wi-Fi access</h2>
        <table>
          <tbody>
            <tr>
              <td>SSID</td>
              <td>CNDA-conference</td>
            </tr>
            <tr>
              <td>Password</td>
              <td>stay-cloud-native!</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="info-card">
        <h2>Emergency numbers</h2>
        <table>
          <tbody>
            <tr>
              <td>Fire service</td>
              <td><a href="tel:122">122</a></td>
            </tr>
            <tr>
              <td>Police</td>
              <td><a href="tel:133">133</a></td>
            </tr>
            <tr>
              <td>Ambulance</td>
              <td><a href="tel:144">144</a></td>
            </tr>
          </tbody>
        </table>
      </section>
    </div>
  </div>
</Layout>

<style>
  .live-page {
    padding: var(--space-8) var(--space-6);
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .page-header h1 {
    font-family: var(--font-heading);
    font-size: 3rem;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .page-header p {
    font-size: 1.25rem;
    color: var(--color-text);
  }

  .live-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .current-sessions-section {
    grid-column: 1 / -1;
    background: var(--color-bg-light);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    text-align: center;
  }

  .current-sessions-section h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-bottom: var(--space-6);
  }

  .current-sessions-section :global(.rooms-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .current-sessions-section :global(.room-sessions) {
    text-align: left;
  }

  .current-sessions-section :global(.room-sessions h3) {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    margin-bottom: var(--space-4);
  }

  .current-sessions-section :global(.session) {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-gray-10);
  }

  .current-sessions-section :global(.session:last-child) {
    border-bottom: none;
  }

  .current-sessions-section :global(.session-time) {
    display: inline-block;
    background: var(--color-pink);
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-2);
  }

  .current-sessions-section :global(.session-title) {
    margin-top: var(--space-2);
  }

  .current-sessions-section :global(.session-title a) {
    color: var(--color-purple);
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .current-sessions-section :global(.session-title a:hover) {
    color: var(--color-pink);
  }

  .info-card {
    background: var(--color-bg-light);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    text-align: center;
  }

  .info-card h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-bottom: var(--space-4);
  }

  .info-card table {
    margin: 0 auto;
    border-spacing: var(--space-3);
  }

  .info-card td:first-child {
    text-align: right;
    font-weight: 600;
    padding-right: var(--space-4);
  }

  .info-card td:last-child {
    text-align: left;
  }

  .info-card a {
    color: var(--color-purple);
    text-decoration: none;
  }

  .info-card a:hover {
    color: var(--color-pink);
  }

  @media (max-width: 768px) {
    .live-page {
      padding: var(--space-6) var(--space-4);
    }

    .page-header h1 {
      font-size: 2rem;
    }

    .page-header p {
      font-size: 1rem;
    }

    .live-content {
      grid-template-columns: 1fr;
    }

    .current-sessions-section :global(.rooms-grid) {
      grid-template-columns: 1fr;
    }

    .info-card table {
      font-size: var(--text-sm);
    }
  }
</style>
