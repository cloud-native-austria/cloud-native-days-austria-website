---
import Layout from "@layouts/Layout.astro";
import Button from "@components/Button.astro";
import CurrentSessions from "@components/CurrentSessions";
import { scheduleUrl } from "../lib/sessionize-app";

const title = "CNDA 2026 - Live";
const description = "Everything you need to know at the event.";
---

<Layout title={title} description={description}>
	<header>
		<h1>{title}</h1>
		<p>{description}</p>
	</header>

	<div>
		<section>
			<h2>Current and upcoming sessions</h2>
			<CurrentSessions client:load />
			<Button href={scheduleUrl} external variant="primary"> See the full schedule </Button>
		</section>

		<section>
			<h2>Wi-Fi access</h2>
			<table>
				<tbody>
					<tr>
						<td>SSID</td>
						<td>CNDA-conference</td>
					</tr>
					<tr>
						<td>Password</td>
						<td>stay-cloud-native!</td>
					</tr>
				</tbody>
			</table>
		</section>

		<section>
			<h2>Emergency numbers</h2>
			<table>
				<tbody>
					<tr>
						<td>Fire service</td>
						<td><a href="tel:122">122</a></td>
					</tr>
					<tr>
						<td>Police</td>
						<td><a href="tel:133">133</a></td>
					</tr>
					<tr>
						<td>Ambulance</td>
						<td><a href="tel:144">144</a></td>
					</tr>
				</tbody>
			</table>
		</section>
	</div>
</Layout>

<style>
	header {
		text-align: center;
		margin-bottom: var(--space-8);
	}

	header h1 {
		font-family: var(--font-heading);
		font-size: var(--text-3xl);
		color: var(--color-text);
		margin-bottom: var(--space-4);
	}

	header p {
		font-size: var(--text-base);
		color: var(--color-text);
	}

	div {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-6);
	}

	section {
		background: var(--color-bg-light);
		border-radius: var(--radius);
		padding: var(--space-6);
		text-align: center;
	}

	section:first-child {
		grid-column: 1 / -1;
	}

	section h2 {
		font-family: var(--font-heading);
		font-size: var(--text-lg);
		margin-bottom: var(--space-4);
	}

	section:first-child h2 {
		margin-bottom: var(--space-6);
	}

	/* CurrentSessions component styles */
	section:first-child :global(.rooms-grid) {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-6);
		margin-bottom: var(--space-6);
	}

	section:first-child :global(.room-sessions) {
		text-align: left;
	}

	section:first-child :global(.room-sessions h3) {
		font-family: var(--font-heading);
		font-size: var(--text-base);
		margin-bottom: var(--space-4);
	}

	section:first-child :global(.session) {
		padding: var(--space-4) 0;
		border-bottom: 1px solid var(--color-gray);
	}

	section:first-child :global(.session:last-child) {
		border-bottom: none;
	}

	section:first-child :global(.session-time) {
		display: inline-block;
		background: var(--color-pink);
		color: var(--color-white);
		font-size: var(--text-base);
		font-weight: 600;
		padding: var(--space-2) var(--space-3);
		border-radius: var(--radius-full);
		margin-bottom: var(--space-2);
	}

	section:first-child :global(.session-title) {
		margin-top: var(--space-2);
	}

	section:first-child :global(.session-title a) {
		color: var(--color-purple);
		text-decoration: none;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	section:first-child :global(.session-title a:hover) {
		color: var(--color-pink);
	}

	/* Table styles for Wi-Fi and Emergency sections */
	table {
		margin: 0 auto;
		border-spacing: var(--space-3);
	}

	td:first-child {
		text-align: right;
		font-weight: 600;
		padding-right: var(--space-4);
	}

	td:last-child {
		text-align: left;
	}

	a {
		color: var(--color-purple);
		text-decoration: none;
	}

	a:hover {
		color: var(--color-pink);
	}

	@media (max-width: 768px) {
		div {
			grid-template-columns: 1fr;
		}

		section:first-child :global(.rooms-grid) {
			grid-template-columns: 1fr;
		}
	}
</style>
