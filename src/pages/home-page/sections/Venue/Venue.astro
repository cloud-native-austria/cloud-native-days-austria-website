---
import { Picture } from "astro:assets";
import venueImage from "./images/venue.webp";

const venueDescription = `apiVersion: event.cloudnativedays.at/v1
kind: Venue
metadata:
  name: cineplexx-wienerberg
  namespace: vienna
spec:
  location:
    address: <a href="https://maps.app.goo.gl/Q22METdvy3f1GFfx8" target="_blank" rel="noopener noreferrer">Wienerbergstraße 11, 1100 Wien</a>
    lat: 48.1680217
    long: 16.3449543
  stages:
    - cinema-hall-4
    - cinema-hall-6
  networking:
    evening-event: nearby
status:
  readiness: "We can't wait to see you there!"`;
---

<section>
	<h2 id="venue">Venue</h2>
	<div>
		<pre aria-label="Venue description"><code set:html={venueDescription} /></pre>
	</div>
	<div>
		<Picture
			src={venueImage}
			alt="CDN Austria Venue - Cineplexx Wienerberg"
			formats={["avif", "webp"]}
		/>
		<a href="https://maps.app.goo.gl/Q22METdvy3f1GFfx8" target="_blank" rel="noopener noreferrer">
			<strong>Cineplexx Wienerberg</strong>

			Wienerbergstraße 11, 1100 Wien</a
		>
	</div>
</section>

<style>
	h2 {
		width: 100%;
		text-align: center;
	}

	section {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-2);
	}

	section > div {
		min-width: 0;
	}

	section > div:last-of-type {
		font-size: var(--text-base);
		display: flex;
		flex-direction: column;
		gap: var(--space-2);

		a {
			text-align: center;
		}
	}

	img {
		max-height: 300px;
		width: auto;
		border-radius: var(--radius);
		object-fit: contain;
	}

	strong {
		display: block;
		font-family: var(--font-heading);
	}

	pre {
		margin: 0;
		padding: var(--space-2);
		max-width: 100%;
		border-radius: var(--radius);
		overflow-x: auto;
		font-family: var(--font-heading);
		font-size: var(--text-base);
		line-height: 1.5;
		background: var(--color-bg-light);
		border: 1px solid var(--color-gray);
	}

	code {
		white-space: pre;
	}

	@media (max-width: 768px) {
		pre {
			font-size: calc(var(--text-base) * 0.9);
		}
	}
</style>
