---
import { getEntry, type CollectionEntry } from "astro:content";
import { Picture } from "astro:assets";

type SponsorTier = CollectionEntry<"sponsors">["data"]["tiers"][number];

const sponsorsEntry = await getEntry("sponsors", "list");
if (!sponsorsEntry) {
	throw new Error("Sponsors data not found in content collection");
}

const sponsors = sponsorsEntry.data.tiers as SponsorTier[];

const tierImageBounds: Record<string, { width: number; height: number }> = {
	gold: { width: 220, height: 110 },
	silver: { width: 200, height: 100 },
	community: { width: 160, height: 80 },
};

function getTierImageBounds(tier: string) {
	return tierImageBounds[tier] ?? tierImageBounds.silver;
}

// Shuffle sponsors at build time for each tier
function shuffleArray<T>(array: T[]): T[] {
	const shuffled = [...array];
	for (let i = shuffled.length - 1; i > 0; i--) {
		const j = Math.floor(Math.random() * (i + 1));
		[shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
	}
	return shuffled;
}
---

<section>
	<h2 id="sponsors">Our Sponsors of CNDA 2026</h2>
	<p>Without them this event wouldn't have been possible</p>
	<ol>
		{
			sponsors.map(({ title, tier, sponsors: tierSponsors }) => (
				<li data-tier={tier}>
					<h3>{title}</h3>
					<ul>
						{shuffleArray(tierSponsors).map(({ name, url, logo }) => {
							const imageBounds = getTierImageBounds(tier);

							return (
								<li>
									<a href={url} target="_blank" rel="noopener noreferrer" aria-label={name}>
										<Picture
											src={logo}
											alt={name}
											width={imageBounds.width}
											height={imageBounds.height}
											fit="inside"
											formats={["avif", "webp"]}
										/>
									</a>
								</li>
							);
						})}
					</ul>
				</li>
			))
		}
	</ol>
</section>

<style>
	section {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-8);
	}

	p {
		color: var(--color-text-light);
	}

	h3 {
		margin-bottom: var(--space-4);
	}

	ol {
		list-style: none;
		padding-left: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-12);
	}

	ol > li > ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		gap: var(--space-8);
	}

	a {
		display: inline-flex;
		padding: var(--space-2);
		border-radius: var(--radius);
		transition: transform var(--transition-fast);
	}

	a:hover {
		transform: scale(1.05);
	}

	a:focus-visible {
		outline: 2px solid var(--color-purple);
		outline-offset: 4px;
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-white) 85%, transparent);
	}

	a img {
		height: auto;
		width: auto;
		object-fit: contain;
	}
</style>
