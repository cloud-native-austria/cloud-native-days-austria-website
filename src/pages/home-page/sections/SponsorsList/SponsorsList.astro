---
import { getEntry, type CollectionEntry } from "astro:content";
import { Picture } from "astro:assets";

type SponsorTier = CollectionEntry<"sponsors">["data"]["tiers"][number];

const sponsorsEntry = await getEntry("sponsors", "list");
if (!sponsorsEntry) {
	throw new Error("Sponsors data not found in content collection");
}

const sponsors = sponsorsEntry.data.tiers as SponsorTier[];

// Shuffle sponsors at build time for each tier
function shuffleArray<T>(array: T[]): T[] {
	const shuffled = [...array];
	for (let i = shuffled.length - 1; i > 0; i--) {
		const j = Math.floor(Math.random() * (i + 1));
		[shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
	}
	return shuffled;
}
---

<section>
	<h2 id="sponsors">Our Sponsors of CNDA 2025</h2>
	<p>Without them this event wouldn't have been possible</p>
	<ol>
		{
			sponsors.map(({ title, tier, sponsors: tierSponsors }) => (
				<li data-tier={tier}>
					<h3>{title}</h3>
					<ul>
						{shuffleArray(tierSponsors).map(({ name, url, logo }) => (
							<li>
								<a href={url} target="_blank" rel="noopener noreferrer" aria-label={name}>
									<Picture
										src={logo}
										alt={name}
										width={200}
										height={100}
										formats={["avif", "webp"]}
									/>
								</a>
							</li>
						))}
					</ul>
				</li>
			))
		}
	</ol>
</section>

<style>
	section {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-8);
	}

	p {
		color: var(--color-text-light);
	}

	h3 {
		margin-bottom: var(--space-4);
	}

	ol {
		list-style: none;
		padding-left: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-12);
	}

	ol > li > ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-8);
	}

	a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-2);
		border-radius: var(--radius);
		transition: transform var(--transition-fast);
	}

	a:hover {
		transform: scale(1.05);
	}

	a:focus-visible {
		outline: 2px solid var(--color-purple);
		outline-offset: 4px;
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-white) 85%, transparent);
	}

	a img {
		height: 70px;
		width: auto;
		max-width: 180px;
		object-fit: contain;
	}

	/* Gold tier - larger logos */
	ol > li[data-tier="gold"] a img {
		height: 80px;
		max-width: 200px;
	}

	/* Community tier - smaller logos */
	ol > li[data-tier="community"] a img {
		height: 50px;
		max-width: 140px;
	}

	@media (max-width: 768px) {
		a img {
			height: 60px;
		}

		ol > li[data-tier="gold"] a img {
			height: 70px;
		}

		ol > li[data-tier="community"] a img {
			height: 45px;
		}
	}
</style>
