---
import PersonCard from "@components/PersonCard.astro";
import SpeakersDetailDialog from "@components/SpeakersDetailDialog.astro";
import Layout from "@layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type Speaker = CollectionEntry<"speakers">["data"];

const speakers = (await getCollection("speakers")).map((entry) => entry.data) as Speaker[];
---

<Layout
	title="Speakers | Cloud Native Days Austria"
	description="Meet the speakers of Cloud Native Days Austria"
>
	<h1>Speakers of 2026</h1>
	<section class="speakers-grid">
		{
			speakers.map((speaker) => (
				<button
					type="button"
					commandfor={`speaker-${speaker.id}`}
					command="show-modal"
					data-speaker-target={`speaker-${speaker.id}`}
					aria-label={`View details for ${speaker.fullName}`}
				>
					<PersonCard
						name={speaker.fullName}
						role={speaker.tagLine}
						image={speaker.profilePicture}
						sizes="(max-width: 768px) 150px, 200px"
					/>
				</button>
			))
		}
	</section>

	<SpeakersDetailDialog speakers={speakers} />

	<style>
		h1 {
			text-align: center;
		}

		.speakers-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
			gap: var(--space-8);
			align-items: start;
			margin-top: var(--space-12);
		}

		.speakers-grid > button {
			all: unset;
			cursor: pointer;
			display: block;
			width: 100%;
			text-align: center;
		}

		.speakers-grid > button:focus-visible {
			outline: 2px solid var(--color-purple);
			outline-offset: 4px;
			border-radius: var(--radius);
		}

		@media (max-width: 768px) {
			.speakers-grid {
				grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
				gap: var(--space-6);
			}
		}
	</style>
</Layout>
