---
import Layout from '@layouts/Layout.astro';
import { Image } from 'astro:assets';
import { fetchSpeakers } from '@lib/sessionize';
import { getSpeakerUrl, getSessionUrl } from '../constants/sessionize-app';

const speakers = await fetchSpeakers();
---

<Layout
  title="Speakers 2025 | Cloud Native Days Austria"
  description="Meet the speakers of Cloud Native Days Austria 2025"
>
  <main class="container">
    <h1>Speakers of 2025</h1>
    <div class="speakers-grid">
      {
        speakers.map((speaker) => (
          <article class="speaker-card">
            <button
              popovertarget={`speaker-${speaker.id}`}
              class="speaker-button"
              aria-label={`View details for ${speaker.fullName}`}
            >
              <div class="image-wrapper">
                <img
                  src={speaker.localProfilePicture}
                  alt={speaker.fullName}
                  class="heptagon"
                  loading="lazy"
                  decoding="async"
                  width="180"
                  height="180"
                />
              </div>
              <h2 class="name">{speaker.fullName}</h2>
              {speaker.tagLine && <p class="tagline">{speaker.tagLine}</p>}
            </button>
          </article>
        ))
      }
    </div>

    <!-- Speaker modals -->
    {
      speakers.map((speaker) => (
        <div id={`speaker-${speaker.id}`} popover class="speaker-modal">
          <div class="modal-header">
            <div class="modal-title">
              <div class="modal-image-wrapper">
                <img
                  src={speaker.localProfilePicture}
                  alt={speaker.fullName}
                  class="heptagon"
                  width="80"
                  height="80"
                />
              </div>
              <div>
                <h2>
                  <a href={getSpeakerUrl(speaker.id)} target="_blank" rel="noopener noreferrer">
                    {speaker.fullName}
                  </a>
                </h2>
                {speaker.tagLine && <p class="modal-tagline">{speaker.tagLine}</p>}
              </div>
            </div>
            <button
              popovertarget={`speaker-${speaker.id}`}
              popovertargetaction="hide"
              class="close-button"
              aria-label="Close modal"
            >
              ✕
            </button>
          </div>

          <div class="modal-content">
            {speaker.bio && (
              <div class="bio">
                <h3>Bio</h3>
                <p>{speaker.bio}</p>
              </div>
            )}

            {speaker.sessions && speaker.sessions.length > 0 && (
              <div class="sessions">
                <h3>Sessions</h3>
                <ul>
                  {speaker.sessions.map((session) => (
                    <li>
                      <a
                        href={getSessionUrl(String(session.id))}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {session.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {speaker.links && speaker.links.length > 0 && (
              <div class="social-links">
                <h3>Connect</h3>
                <div class="links-grid">
                  {speaker.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="social-link"
                      title={link.title}
                    >
                      <span class="link-type">{link.linkType}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      ))
    }
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    text-align: center;
    margin-bottom: var(--space-12);
    color: var(--color-text);
  }

  .speakers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  .speaker-card {
    text-align: center;
  }

  .speaker-button {
    all: unset;
    cursor: pointer;
    display: block;
    width: 100%;
    transition: transform 0.2s ease;
  }

  .speaker-button:hover {
    transform: translateY(-4px);
  }

  .speaker-button:focus-visible {
    outline: 2px solid var(--color-purple);
    outline-offset: 4px;
    border-radius: var(--radius-md);
  }

  .image-wrapper {
    width: 180px;
    height: 180px;
    margin-inline: auto;
    margin-bottom: var(--space-4);
    filter: drop-shadow(0 8px 16px rgba(38, 47, 89, 0.15));
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .name {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-2);
    color: var(--color-text);
  }

  .tagline {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.4;
  }

  /* Modal styles */
  .speaker-modal {
    margin: auto;
    padding: 0;
    border: none;
    border-radius: var(--radius-lg);
    max-width: 600px;
    max-height: 85vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }

  .speaker-modal::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6);
    border-bottom: 1px solid var(--color-gray-10);
    position: sticky;
    top: 0;
    background: var(--color-white);
    z-index: 1;
  }

  .modal-title {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    flex: 1;
  }

  .modal-image-wrapper {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    filter: drop-shadow(0 4px 8px rgba(38, 47, 89, 0.15));
  }

  .modal-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .modal-header h2 {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }

  .modal-header h2 a {
    color: var(--color-purple);
    text-decoration: none;
  }

  .modal-header h2 a:hover {
    color: var(--color-pink);
    text-decoration: underline;
  }

  .modal-tagline {
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  .close-button {
    all: unset;
    cursor: pointer;
    font-size: var(--text-2xl);
    line-height: 1;
    color: var(--color-text-light);
    padding: var(--space-2);
    transition: color 0.2s ease;
    flex-shrink: 0;
  }

  .close-button:hover {
    color: var(--color-text);
  }

  .close-button:focus-visible {
    outline: 2px solid var(--color-purple);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .modal-content {
    padding: var(--space-6);
  }

  .modal-content h3 {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-3);
    color: var(--color-text);
  }

  .bio {
    margin-bottom: var(--space-6);
  }

  .bio p {
    line-height: 1.6;
    color: var(--color-text);
    white-space: pre-wrap;
  }

  .sessions {
    margin-bottom: var(--space-6);
  }

  .sessions ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sessions li {
    margin-bottom: var(--space-2);
  }

  .sessions a {
    color: var(--color-purple);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .sessions a:hover {
    color: var(--color-pink);
    text-decoration: underline;
  }

  .social-links {
    margin-bottom: var(--space-4);
  }

  .links-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .social-link {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-light);
    color: var(--color-purple);
    text-decoration: none;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .social-link:hover {
    background: var(--color-purple);
    color: var(--color-white);
    transform: scale(1.05);
  }

  .social-link:focus-visible {
    outline: 2px solid var(--color-purple);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .container {
      padding: var(--space-6) var(--space-4);
    }

    h1 {
      font-size: var(--text-3xl);
      margin-bottom: var(--space-8);
    }

    .speakers-grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: var(--space-6);
    }

    .image-wrapper {
      width: 140px;
      height: 140px;
    }

    .modal-header {
      padding: var(--space-4);
    }

    .modal-title {
      flex-direction: column;
      align-items: flex-start;
    }

    .modal-image-wrapper {
      width: 60px;
      height: 60px;
    }

    .modal-content {
      padding: var(--space-4);
    }
  }
</style>
